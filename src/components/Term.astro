---
// Inline glossary term: shows a distinct style and reveals a hint on
// hover or keyboard focus. No client-side JavaScript; an optional `math`
// formula is rendered to HTML with KaTeX at build time.
// Usage:  <Term def="the hint text" math="a + b = c">word</Term>
import katex from 'katex';
interface Props {
  def: string;
  math?: string;
}
const { def, math } = Astro.props;
const mathHtml = math ? katex.renderToString(math, { throwOnError: false }) : '';
---
<span class="term" tabindex="0"><slot /><span class="term-tip" role="tooltip">{def}{math && <span class="term-math" set:html={mathHtml} />}</span></span>

<style>
  .term {
    position: relative;
    color: var(--accent);
    text-decoration: underline dotted;
    text-underline-offset: 3px;
    cursor: help;
  }
  .term-tip {
    position: absolute;
    left: 50%;
    bottom: 100%;
    transform: translateX(-50%);
    margin-bottom: 8px;
    width: max-content;
    max-width: 22rem;
    background: var(--surface);
    color: var(--ink);
    border: 1px solid var(--line);
    border-radius: 8px;
    padding: 0.5rem 0.7rem;
    font-family: var(--sans);
    font-size: 0.82rem;
    font-weight: 400;
    font-style: normal;
    line-height: 1.5;
    text-align: left;
    text-decoration: none;
    box-shadow: 0 6px 22px rgba(0, 0, 0, 0.14);
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.12s ease;
    z-index: 20;
    pointer-events: none;
  }
  .term-math {
    display: block;
    text-align: center;
    margin-top: 0.5rem;
    overflow-x: auto;
  }
  .term:hover .term-tip,
  .term:focus .term-tip,
  .term:focus-within .term-tip {
    opacity: 1;
    visibility: visible;
  }
</style>
