---
// Static figure: the vector A with axes and components (3, 4), now with the
// unit basis vectors e_x, e_y marked on the axes. Same geometry as VectorFigure
// (40 px per unit, origin at 56,208). Inline SVG, adapts to light/dark.
---
<figure class="figure vecbasisfig">
  <svg viewBox="0 0 360 260" role="img"
    aria-label="Vector A with its components 3 and 4, and the unit basis vectors e_x and e_y along the axes">
    <g class="grid">
      <line x1="96"  y1="24" x2="96"  y2="236" />
      <line x1="136" y1="24" x2="136" y2="236" />
      <line x1="176" y1="24" x2="176" y2="236" />
      <line x1="216" y1="24" x2="216" y2="236" />
      <line x1="256" y1="24" x2="256" y2="236" />
      <line x1="296" y1="24" x2="296" y2="236" />
      <line x1="24" y1="168" x2="336" y2="168" />
      <line x1="24" y1="128" x2="336" y2="128" />
      <line x1="24" y1="88"  x2="336" y2="88" />
      <line x1="24" y1="48"  x2="336" y2="48" />
    </g>

    <!-- axes -->
    <line class="axis" x1="24" y1="208" x2="336" y2="208" />
    <line class="axis" x1="56" y1="236" x2="56"  y2="24" />
    <polygon class="axis-head" points="336,208 328,204 328,212" />
    <polygon class="axis-head" points="56,24 52,32 60,32" />

    <!-- projection lines to the axes -->
    <line class="proj" x1="176" y1="48" x2="176" y2="208" />
    <line class="proj" x1="176" y1="48" x2="56"  y2="48" />

    <!-- unit basis vectors on the axes -->
    <line class="basis" x1="56" y1="208" x2="96" y2="208" />
    <polygon class="basis-head" points="96,208 88,204 88,212" />
    <line class="basis" x1="56" y1="208" x2="56" y2="168" />
    <polygon class="basis-head" points="56,168 52,176 60,176" />

    <!-- the vector -->
    <line class="vec" x1="56" y1="208" x2="176" y2="48" />
    <polygon class="vec-head" points="176,48 173.6,61.2 164,54" />

    <!-- labels -->
    <text class="lbl-axis" x="340" y="213">x</text>
    <text class="lbl-axis" x="48"  y="18">y</text>
    <text class="lbl-comp" x="171" y="228">3</text>
    <text class="lbl-comp" x="34"  y="53">4</text>
    <text class="lbl-vec"  x="98"  y="112">A</text>
    <text class="lbl-basis" x="66" y="226">e<tspan dy="3" font-size="10">x</tspan></text>
    <text class="lbl-basis" x="30" y="190">e<tspan dy="3" font-size="10">y</tspan></text>
  </svg>
  <figcaption>The same picture with the unit basis vectors <em>e</em><sub>x</sub>, <em>e</em><sub>y</sub>
    marked on the axes. The components (3, 4) are the amounts of each: <em>A</em> = 3 <em>e</em><sub>x</sub> + 4 <em>e</em><sub>y</sub>.</figcaption>
</figure>

<style>
  .vecbasisfig svg { width: 100%; max-width: 420px; height: auto; }
  .vecbasisfig .grid line { stroke: rgba(128, 128, 128, 0.14); stroke-width: 1; }
  .vecbasisfig .axis { stroke: var(--muted); stroke-width: 1.5; }
  .vecbasisfig .axis-head { fill: var(--muted); }
  .vecbasisfig .proj { stroke: rgba(128, 128, 128, 0.6); stroke-width: 1.5; stroke-dasharray: 5 4; }
  .vecbasisfig .basis { stroke: var(--ink); stroke-width: 3; stroke-linecap: round; }
  .vecbasisfig .basis-head { fill: var(--ink); }
  .vecbasisfig .vec { stroke: var(--accent); stroke-width: 2.5; }
  .vecbasisfig .vec-head { fill: var(--accent); }
  .vecbasisfig .lbl-axis { fill: var(--muted); font: 13px var(--sans); }
  .vecbasisfig .lbl-comp { fill: var(--accent); font: 600 14px var(--sans); }
  .vecbasisfig .lbl-vec  { fill: var(--accent); font: italic 700 16px var(--serif); }
  .vecbasisfig .lbl-basis { fill: var(--ink); font: italic 15px var(--serif); }
</style>
