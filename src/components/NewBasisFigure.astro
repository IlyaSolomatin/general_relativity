---
// Static figure: the same arrow A with BOTH bases on one picture.
// Old east-north axes (grey solid) + basis e_x, e_y (dark);
// new axes aligned with A (green dashed) + basis e_x', e_y' (green);
// arrow A in accent. Green basis vectors drawn topmost. Styling inline.
const GREEN = '#2e8b63';
---
<figure class="figure">
  <svg viewBox="0 0 420 320" style="width:100%; max-width:420px; height:auto;" role="img"
    aria-label="One arrow A shown with two coordinate frames at once: the east-north axes and axes aligned with A.">
    <!-- OLD axes (east-north), grey solid -->
    <g style="stroke: var(--muted); fill: var(--muted); stroke-width: 1.5;">
      <line x1="45" y1="235" x2="360" y2="235" />
      <polygon points="360,235 352,231 352,239" stroke="none" />
      <line x1="165" y1="300" x2="165" y2="60" />
      <polygon points="165,60 161,68 169,68" stroke="none" />
    </g>

    <!-- NEW axes (aligned with A), green dashed; x' extended well past A's tip -->
    <g style={`stroke: ${GREEN}; fill: ${GREEN}; stroke-width: 1.5;`}>
      <line x1="134.4" y1="275.8" x2="318" y2="31" stroke-dasharray="5 4" />
      <polygon points="318,31 315.8,40.6 309.4,35.8" stroke="none" />
      <line x1="246.6" y1="296.2" x2="69.8" y2="163.6" stroke-dasharray="5 4" />
      <polygon points="69.8,163.6 78.6,165.2 73.8,171.6" stroke="none" />
    </g>

    <!-- OLD basis vectors (dark) -->
    <g style="stroke: var(--ink); fill: var(--ink); stroke-width: 3; stroke-linecap: round;">
      <line x1="165" y1="235" x2="199" y2="235" />
      <polygon points="199,235 191,231 191,239" stroke="none" />
      <line x1="165" y1="235" x2="165" y2="201" />
      <polygon points="165,201 161,209 169,209" stroke="none" />
    </g>

    <!-- the arrow A -->
    <g style="stroke: var(--accent); fill: var(--accent); stroke-width: 3.5; stroke-linecap: round;">
      <line x1="165" y1="235" x2="267" y2="99" />
      <polygon points="267,99 263.8,111.6 255.8,105.6" stroke="none" />
    </g>

    <!-- NEW basis vectors (green) — drawn topmost -->
    <g style={`stroke: ${GREEN}; fill: ${GREEN}; stroke-width: 3; stroke-linecap: round;`}>
      <line x1="165" y1="235" x2="185.4" y2="207.8" />
      <polygon points="185.4,207.8 183,216 178.2,212.4" stroke="none" />
      <line x1="165" y1="235" x2="137.8" y2="214.6" />
      <polygon points="137.8,214.6 146,217 142.4,221.8" stroke="none" />
    </g>

    <!-- labels -->
    <g style="font-family: Georgia, serif; font-style: italic; font-size: 14px;">
      <text x="364" y="240" style="fill: var(--muted);">x</text>
      <text x="152" y="56"  style="fill: var(--muted);">y</text>
      <text x="322" y="29"  style={`fill: ${GREEN};`}>x<tspan dy="3" font-size="10">′</tspan></text>
      <text x="50"  y="160" style={`fill: ${GREEN};`}>y<tspan dy="3" font-size="10">′</tspan></text>
      <text x="176" y="252" style="fill: var(--ink);">e<tspan dy="3" font-size="10">x</tspan></text>
      <text x="168" y="196" style="fill: var(--ink);">e<tspan dy="3" font-size="10">y</tspan></text>
      <text x="200" y="214" style={`fill: ${GREEN};`}>e<tspan dy="3" font-size="10">x′</tspan></text>
      <text x="98"  y="206" style={`fill: ${GREEN};`}>e<tspan dy="3" font-size="10">y′</tspan></text>
      <text x="240" y="100" style="fill: var(--accent); font-weight: 700; font-size: 16px;">A</text>
    </g>
  </svg>
  <figcaption>Old east–north basis (dark): <em>A</em> = 3 <em>e</em><sub>x</sub> + 4 <em>e</em><sub>y</sub>.
    New basis aligned with <em>A</em> (green): <em>A</em> = 5 <em>e</em><sub>x′</sub> + 0 <em>e</em><sub>y′</sub>.</figcaption>
</figure>
