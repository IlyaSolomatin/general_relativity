---
import 'katex/dist/katex.min.css';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  frontmatter?: { title?: string; description?: string };
}

const { title, description, frontmatter } = Astro.props;
const pageTitle = frontmatter?.title ?? title ?? 'General Relativity, brick by brick';
const pageDesc =
  frontmatter?.description ??
  description ??
  'An interactive course in general relativity, built from first principles.';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={pageDesc} />
    <title>{pageTitle}</title>
  </head>
  <body>
    <div class="layout">
      <header class="site-header">
        <a href="/" class="brand">GR<span>·</span>from scratch</a>
        <nav>
          <a href="/">Contents</a>
        </nav>
      </header>
      <main class="content">
        <slot />
      </main>
      <footer class="site-footer">
        <p>Built brick by brick, with rigor. · <a href="https://github.com/IlyaSolomatin/general_relativity">source</a></p>
      </footer>
    </div>

    <script>
      // Cross-references for numbered equations. The number shown beside each
      // equation is drawn by CSS (a counter); here we fill each <EqRef> with the
      // matching number, assigned in document order among `.equation` blocks.
      const equations = Array.from(document.querySelectorAll('.equation'));
      const numByLabel = new Map();
      equations.forEach((el, i) => {
        const label = el.getAttribute('data-eq-label');
        if (label) numByLabel.set(label, i + 1);
      });
      document.querySelectorAll('.eq-ref').forEach((a) => {
        const label = a.getAttribute('data-eq-ref');
        const n = label ? numByLabel.get(label) : undefined;
        if (n) a.textContent = '(' + n + ')';
      });
    </script>
  </body>
</html>
